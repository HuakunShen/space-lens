{
  "name": "space-lens-repo",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "packages/node"
  ],
  "scripts": {
    "artifacts": "yarn workspace space-lens artifacts",
    "bench": "yarn workspace space-lens bench",
    "build": "yarn workspace space-lens build",
    "build:debug": "yarn workspace space-lens build:debug",
    "format": "run-p format:prettier format:rs format:toml",
    "format:prettier": "prettier . -w",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt --all",
    "lint": "yarn workspace space-lens lint",
    "test": "cargo test --workspace && yarn workspace space-lens test",
    "typecheck": "yarn workspace space-lens typecheck"
  },
  "devDependencies": {
    "@taplo/cli": "^0.7.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  },
  "packageManager": "yarn@4.14.1"
}
