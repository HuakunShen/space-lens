{
  "name": "@space-lens/cli",
  "type": "module",
  "version": "0.2.0",
  "description": "OpenTUI-powered CLI for Space Lens scanning and cleanup.",
  "bin": {
    "spacelens": "dist/cli.mjs"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "bun src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/cli": "^0.75.2",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.107.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "@effect/typeclass": "^0.40.0",
    "@opentui/core": "^0.4.1",
    "effect": "^3.21.3",
    "space-lens": "^0.2.0",
    "web-tree-sitter": "0.25.10"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
